{
  "name": "territory-run-functions",
  "description": "Firebase Cloud Functions for Territory Run",
  "version": "1.0.0",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
