    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/node": "^8.54.0",
    "date-fns": "^4.1.0",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "~5.8.2"
  },
  "private": true
}
